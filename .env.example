# Jarvis bridge config — copy to .env and fill in

# Where Claude Code runs from. This is the "brain" dir whose CLAUDE.md + fleet.md
# define who Jarvis is and what it knows. Defaults to ./hub
JARVIS_HUB=./hub

# Port for the HUD + websocket bridge. (Never 3000.)
PORT=4317

# Root that the fleet scanner walks to discover your projects.
PROJECTS_ROOT=/Users/michaelaubry/Documents/projects

# Claude model the bridge drives. Leave blank to use your CC default.
JARVIS_MODEL=

# Permission mode for headless runs: bypassPermissions | acceptEdits | default
# bypassPermissions = no prompts (true Jarvis), but it can do anything. localhost only.
JARVIS_PERMISSION_MODE=bypassPermissions
