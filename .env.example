# Jarvis bridge config — copy to .env and fill in

# Where Claude Code runs from. This is the "brain" dir whose CLAUDE.md + fleet.md
# define who Jarvis is and what it knows. Defaults to ./hub
JARVIS_HUB=./hub

# Port for the HUD + websocket bridge. (Never 3000.)
PORT=4317

# Root that the fleet scanner walks to discover your projects.
PROJECTS_ROOT=/Users/michaelaubry/Documents/projects

# Claude model the bridge drives. Leave blank to use your CC default.
JARVIS_MODEL=

# Permission mode for headless runs: bypassPermissions | acceptEdits | default
# bypassPermissions = no prompts (true Jarvis), but it can do anything. localhost only.
JARVIS_PERMISSION_MODE=bypassPermissions

# --- Local voice (offline, no Python — runs as ONNX in Node) ---
# STT: Whisper via @huggingface/transformers. whisper-base.en = good balance;
# whisper-tiny.en = faster/less accurate. Models download once to a local cache.
JARVIS_STT_MODEL=onnx-community/whisper-base.en
# TTS: Kokoro-82M via kokoro-js. q8 = fast, fp32 = best quality.
JARVIS_TTS_MODEL=onnx-community/Kokoro-82M-v1.0-ONNX
JARVIS_TTS_DTYPE=q8
# Voice: bm_george / bm_lewis (British male), am_michael / am_adam (US male),
# af_heart / bf_emma (female), etc.
JARVIS_VOICE=bm_george

# --- Business data (MCP servers, already registered in user scope) ---
# RevenueCat: a v2 SECRET API key (app.revenuecat.com -> Project settings -> API keys,
# "New" -> v2). The revenuecat MCP expands this at runtime.
REVENUECAT_V2_API_KEY=
# Google Search Console: no env var — the gsc MCP reads an OAuth client-secrets JSON at
#   ~/.config/jarvis/gsc_client_secret.json
# Create one in Google Cloud Console (APIs & Services -> Credentials -> OAuth client ID ->
# Desktop app), download the JSON, save it to that path. First run opens a browser to
# authorize the GSC account. (PostHog is already connected via POSTHOG_AUTH_HEADER.)
